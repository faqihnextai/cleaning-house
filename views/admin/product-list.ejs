<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kelola Jasa - CleanHouse</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3 mb-5">
        <div class="container">
            <a class="navbar-brand fw-bold text-info" href="/">✨ CleanHouse</a>
        </div>
    </nav>

    <div class="container">
        <div class="row">
            <div class="col-md-3 mb-4">
                <div class="list-group shadow-sm">
                    <a href="/admin/dashboard" class="list-group-item list-group-item-action">Dashboard Admin</a>
                    <a href="/admin/products" class="list-group-item list-group-item-action active bg-info border-info">Kelola Layanan Jasa</a>
                </div>
            </div>

            <div class="col-md-9">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2>Daftar Jasa Pembersihan</h2>
                    <a href="/admin/products/add" class="btn btn-info text-white btn-sm">+ Tambah Jasa Baru</a>
                </div>

                <% if (typeof msg !== 'undefined' && msg === 'success_delete') { %>
                    <div class="alert alert-success py-2 small">Data layanan berhasil dihapus!</div>
                <% } %>

                <div class="table-responsive bg-white p-3 rounded shadow-sm">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th width="5%">No</th>
                                <th>Nama Layanan</th>
                                <th>Harga</th>
                                <th>Kapasitas/Stok Harian</th>
                                <th width="20%" class="text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (services.length === 0) { %>
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">Belum ada layanan jasa yang didaftarkan.</td>
                                </tr>
                            <% } else { %>
                                <% services.forEach((srv, index) => { %>
                                    <tr>
                                        <td><%= index + 1 %></td>
                                        <td>
                                            <strong><%= srv.name %></strong>
                                            <small class="d-block text-muted text-truncate" style="max-width: 300px;"><%= srv.description %></small>
                                        </td>
                                        <td>Rp <%= srv.price.toLocaleString('id-ID') %></td>
                                        <td><%= srv.stock %> Sesi</td>
                                        <td class="text-center">
                                            <a href="/admin/products/edit/<%= srv.id %>" class="btn btn-warning btn-sm me-1">Edit</a>
                                            <a href="/admin/products/delete/<%= srv.id %>" class="btn btn-danger btn-sm" onclick="return confirm('Yakin ingin menghapus layanan ini?')">Hapus</a>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>