<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Admin - CleanHouse</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Source+Sans+3:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        body { font-family: 'Source Sans 3', sans-serif; }
        h1, h2, h3, h4, .font-display { font-family: 'Playfair Display', serif; letter-spacing: -0.02em; }
    </style>
</head>
<body class="bg-[#FAFAF9] text-[#1C1917] min-h-screen flex flex-col justify-between antialiased">

    <nav class="bg-[#FAFAF9]/80 backdrop-blur-md sticky top-0 z-50 border-b border-[#D6D3D1]"> 
        <div class="max-w-[1200px] mx-auto px-6 py-4 flex items-center justify-between"> 
            <a href="/" class="text-2xl font-bold text-[#C2410C] font-display">CleanHouse.</a> 
            <a class="text-[#DC2626] font-semibold text-[14px] hover:underline" href="/auth/logout">Logout</a> [cite: 134]
        </div> [cite: 134]
    </nav> [cite: 134]

    <main class="max-w-[1200px] mx-auto w-full px-6 py-12 flex-1">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
            
            <aside class="col-span-1">
                <div class="bg-[#F5F5F4] rounded-[12px] border border-[#D6D3D1] overflow-hidden flex flex-col text-[14px]">
                    <a href="/admin/dashboard" class="px-4 py-3 text-[#C2410C] font-semibold bg-[#FAFAF9] border-l-[3px] border-l-[#C2410C]">Dashboard Admin</a> [cite: 134]
                    <a href="/admin/products" class="px-4 py-3 text-[#57534E] hover:bg-[#E7E5E4] transition-colors">Kelola Layanan Jasa</a> [cite: 135]
                    <a href="/" class="px-4 py-3 text-[#57534E] hover:bg-[#E7E5E4] transition-colors border-t border-[#D6D3D1]/40">Lihat Beranda Toko</a> [cite: 135]
                </div>
            </aside>

            <section class="col-span-1 md:col-span-3"> [cite: 135]
                <h2 class="text-4xl font-bold text-[#1C1917] mb-2 font-display">Panel Kontrol Admin</h2> [cite: 136]
                <p class="text-[#57534E] text-[16px]">Selamat datang kembali di sistem manajemen operasional CleanHouse.</p> [cite: 136]
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-8"> [cite: 136]
                    
                    <div class="bg-[#F5F5F4] border border-[#D6D3D1] rounded-[12px] p-6 relative overflow-hidden flex flex-col justify-between h-32 shadow-[0_4px_16px_rgba(28,25,23,0.02)] border-l-4 border-l-[#C2410C]"> [cite: 137]
                        <h6 class="text-[12px] font-semibold text-[#78716C] uppercase tracking-wide">Total Jenis Jasa</h6> [cite: 137]
                        <h2 class="text-4xl font-bold text-[#1C1917] font-display mt-2"><%= totalLayanan %></h2> [cite: 138]
                    </div>
                    
                    <div class="bg-[#F5F5F4] border border-[#D6D3D1] rounded-[12px] p-6 relative overflow-hidden flex flex-col justify-between h-32 shadow-[0_4px_16px_rgba(28,25,23,0.02)] border-l-4 border-l-[#16A34A]"> [cite: 139]
                        <h6 class="text-[12px] font-semibold text-[#78716C] uppercase tracking-wide">Total Pesanan Masuk</h6> [cite: 140]
                        <h2 class="text-4xl font-bold text-[#1C1917] font-display mt-2"><%= totalPesanan %></h2> [cite: 140]
                    </div> [cite: 141]
                    
                </div>
            </section>
        </div>
    </main>

    <footer class="bg-[#F5F5F4] text-[#78716C] py-6 border-t border-[#D6D3D1]">
        <div class="max-w-[1200px] mx-auto px-6 text-center text-[14px]">
            &copy; 2026 CleanHouse. Tangerang, Indonesia.
        </div>
    </footer>
</body>
</html>