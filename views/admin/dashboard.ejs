<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Admin - CleanHouse</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3 mb-5">
        <div class="container">
            <a class="navbar-brand fw-bold text-info" href="/">✨ CleanHouse</a>
            <div class="navbar-nav ms-auto small">
                <a class="btn btn-outline-danger btn-sm" href="/auth/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="row">
            <div class="col-md-3 mb-4">
                <div class="list-group shadow-sm">
                    <a href="/admin/dashboard" class="list-group-item list-group-item-action active bg-info border-info">Dashboard Admin</a>
                    <a href="/admin/products" class="list-group-item list-group-item-action">Kelola Layanan Jasa</a>
                    <a href="/" class="list-group-item list-group-item-action">Lihat Beranda Toko</a>
                </div>
            </div>

            <div class="col-md-9">
                <h2 class="mb-4">Panel Kontrol Admin</h2>
                <p class="text-muted">Selamat datang kembali di sistem manajemen operasional CleanHouse.</p>
                
                <div class="row g-3 mt-2">
                    <div class="col-6 col-md-4">
                        <div class="card bg-primary text-white border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="card-title text-white-50">Total Jenis Jasa</h6>
                                <h2 class="display-6 fw-bold"><%= totalLayanan %></h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4">
                        <div class="card bg-success text-white border-0 shadow-sm">
                            <div class="card-body">
                                <h6 class="card-title text-white-50">Total Pesanan Masuk</h6>
                                <h2 class="display-6 fw-bold"><%= totalPesanan %></h2>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>