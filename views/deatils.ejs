<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= service.name %> - CleanHouse</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col justify-between">

    <nav class="bg-white shadow-sm border-b border-slate-200">
        <div class="max-w-4xl mx-auto px-4 py-4">
            <a href="/" class="text-xl font-bold text-blue-600 tracking-wide">&larr; CleanHouse.</a>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto px-4 py-12 flex-1 w-full">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 md:p-12">
            <span class="bg-blue-50 text-blue-700 text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wider">Layanan Pilihan</span>
            <h1 class="text-3xl font-extrabold text-slate-900 mt-4 mb-2"><%= service.name %></h1>
            
            <p class="text-2xl font-bold text-amber-600 mb-6">
                Rp <%= service.price.toLocaleString('id-ID') %> <span class="text-sm font-normal text-slate-400">/ paket</span>
            </p>
            
            <hr class="border-slate-100 my-6" />

            <h3 class="text-lg font-semibold text-slate-900 mb-2">Deskripsi Layanan</h3>
            <p class="text-slate-600 leading-relaxed mb-8"><%= service.description %></p>

            <button onclick="alert('Fitur pemesanan akan segera datang!')" class="w-full md:w-auto bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-xl shadow-md transition text-center inline-block">
                Pesan Layanan Sekarang
            </button>
        </div>
    </main>

    <footer class="bg-slate-900 text-slate-400 py-6 border-t border-slate-800">
        <div class="max-w-4xl mx-auto px-4 text-center text-sm">
            <p>&copy; 2026 CleanHouse Inc. Semua Hak Dilindungi.</p>
        </div>
    </footer>

</body>
</html>