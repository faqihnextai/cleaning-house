<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CleanHouse - Layanan Kebersihan Profesional</title>
    <!-- Fonts & Tailwind -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Source+Sans+3:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        body { font-family: 'Source Sans 3', sans-serif; }
        h1, h2, h3, h4, h5, .font-display { font-family: 'Playfair Display', serif; letter-spacing: -0.02em; }
    </style>
</head>
<body class="bg-[#FAFAF9] text-[#1C1917] min-h-screen flex flex-col justify-between antialiased">

    <!-- Navigation -->
    <nav class="bg-[#FAFAF9]/80 backdrop-blur-md sticky top-0 z-50 border-b border-[#D6D3D1]">
        <div class="max-w-[1200px] mx-auto px-6 py-4 flex items-center justify-between">
            <a href="/" class="text-2xl font-bold text-[#C2410C] font-display">CleanHouse.</a>
            <div class="flex items-center gap-6 text-[14px]">
                <a class="font-semibold text-[#C2410C]" href="/">Katalog Jasa</a>
                <a class="text-[#57534E] hover:text-[#1C1917] transition-colors" href="/tentang">Tentang Kami</a>
                <% if (user) { %>
                    <span class="bg-[#E7E5E4] text-[#1C1917] px-3 py-1 rounded-full text-[12px] font-semibold">
                        <%= user.name %> (<%= user.role %>)
                    </span>
                    <a class="text-[#DC2626] font-semibold hover:underline" href="/auth/logout">Logout</a>
                <% } else { %>
                    <a class="bg-[#C2410C] hover:bg-[#9A3412] text-white font-semibold h-[32px] px-3 flex items-center justify-center rounded-[8px] text-[12px] transition-all" href="/auth/login">Masuk Akun</a>
                <% } %>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-[1200px] mx-auto px-6 py-12 flex-1 w-full">
        <div class="text-center max-w-2xl mx-auto mb-12">
            <h1 class="text-5xl font-bold text-[#1C1917] mb-4">Layanan Kebersihan Profesional</h1>
            <p class="text-[#57534E] text-[16px]">Solusi praktis untuk rumah yang bersih, sehat, dan nyaman. Pilih layanan jasa panggilan kami sesuai kebutuhan Anda.</p>
        </div>

        <!-- Grid Jasa -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <% if (services.length === 0) { %>
                <div class="col-span-1 md:col-span-3 text-center py-12">
                    <div class="bg-[#D97706]/10 border border-[#D97706] text-[#D97706] inline-block px-6 py-3 rounded-[12px] text-[14px]">
                        Saat ini semua kuota harian layanan jasa kami sudah penuh. Silakan cek kembali nanti.
                    </div>
                </div>
            <% } else { %>
                <% services.forEach(srv => { %>
                    <div class="bg-[#F5F5F4] rounded-[12px] border border-[#D6D3D1] transition-all duration-150 hover:-translate-y-0.5 hover:shadow-[0_4px_16px_rgba(28,25,23,0.06)] flex flex-col overflow-hidden relative">
                        <!-- Project Color Strip -->
                        <div class="h-1 w-full bg-[#C2410C]"></div>
                        
                        <div class="p-6 flex flex-col flex-1">
                            <h5 class="text-2xl font-bold text-[#1C1917] mb-2"><%= srv.name %></h5>
                            <p class="text-[#57534E] text-[14px] flex-grow leading-relaxed"><%= srv.description %></p>
                            
                            <div class="mt-4 pt-4 border-t border-[#D6D3D1]">
                                <span class="block text-[#78716C] text-[12px] mb-1">
                                    Sisa Kuota Hari Ini: <strong class="text-[#1C1917]"><%= srv.stock %> Sesi</strong>
                                </span>
                                <h4 class="text-2xl font-bold text-[#C2410C]">Rp <%= srv.price.toLocaleString('id-ID') %></h4>
                            </div>
                            
                            <form action="/beli" method="POST" class="mt-4">
                                <input type="hidden" name="product_id" value="<%= srv.id %>">
                                <div class="flex items-center justify-between gap-4 mb-4">
                                    <label class="text-[14px] font-semibold text-[#57534E]">Jumlah Sesi:</label>
                                    <input type="number" name="quantity" class="w-20 border border-[#D6D3D1] bg-[#FAFAF9] rounded-[8px] p-2 text-center text-[16px] focus:outline-none focus:border-[#C2410C] focus:ring-[3px] focus:ring-[#C2410C]/12" value="1" min="1" max="<%= srv.stock %>" required>
                                </div>
                                <button type="submit" class="w-full bg-[#C2410C] hover:bg-[#9A3412] hover:shadow-[0_4px_12px_rgba(194,65,12,0.25)] text-white font-semibold h-[40px] px-4 rounded-[8px] text-[14px] transition-all duration-150 cursor-pointer">
                                    Pesan Jasa Sekarang
                                </button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-[#F5F5F4] text-[#78716C] py-6 border-t border-[#D6D3D1]">
        <div class="max-w-[1200px] mx-auto px-6 text-center text-[14px]">
            &copy; 2026 CleanHouse. Tangerang, Indonesia.
        </div>
    </footer>
</body>
</html>