<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CleanHouse - Layanan Kebersihan Profesional</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3 mb-5">
        <div class="container">
            <a class="navbar-brand fw-bold text-info" href="/">✨ CleanHouse</a>
            <div class="navbar-nav ms-auto small align-items-center">
                <a class="nav-link active me-3" href="/">Katalog Jasa</a>
                <a class="nav-link text-white-50 me-3" href="/tentang">Tentang Kami</a>
                <% if (user) { %>
                    <span class="navbar-text text-white bg-secondary px-3 py-1 rounded-pill me-2">Halo, <%= user.name %> (<%= user.role %>)</span>
                    <a class="btn btn-outline-danger btn-sm" href="/auth/logout">Logout</a>
                <% } else { %>
                    <a class="btn btn-info text-white btn-sm" href="/auth/login">Masuk Akun</a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="row mb-5 text-center">
            <div class="col-lg-8 mx-auto">
                <h1 class="display-5 fw-bold text-info">Layanan Kebersihan Profesional</h1>
                <p class="lead text-muted">Solusi praktis untuk rumah yang bersih, sehat, dan nyaman. Pilih layanan jasa panggilan kami sesuai kebutuhan Anda.</p>
            </div>
        </div>

        <div class="row g-4">
            <% if (services.length === 0) { %>
                <div class="col-12 text-center py-5">
                    <div class="alert alert-warning d-inline-block px-4">
                        Saat ini semua kuota harian layanan jasa kami sudah penuh. Silakan cek kembali nanti.
                    </div>
                </div>
            <% } else { %>
                <% services.forEach(srv => { %>
                    <div class="col-md-4">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="card-body d-flex flex-column p-4">
                                <h5 class="card-title fw-bold text-dark mb-2"><%= srv.name %></h5>
                                <p class="card-text text-muted small flex-grow-1"><%= srv.description %></p>
                                <div class="mt-3 pt-3 border-top">
                                    <span class="d-block text-secondary small mb-1">Sisa Kuota Hari Ini: <strong><%= srv.stock %> Sesi</strong></span>
                                    <h4 class="text-info fw-bold mb-0">Rp <%= srv.price.toLocaleString('id-ID') %></h4>
                                </div>
                                
                                <form action="/beli" method="POST" class="mt-3">
                                    <input type="hidden" name="product_id" value="<%= srv.id %>">
                                    <div class="row g-2 align-items-center mb-3">
                                        <div class="col-7">
                                            <label class="small text-muted mb-1">Jumlah Sesi / Unit:</label>
                                        </div>
                                        <div class="col-5">
                                            <input type="number" name="quantity" class="form-control form-control-sm text-center" value="1" min="1" max="<%= srv.stock %>" required>
                                        </div>
                                    </div>
                                    <button type="submit" class="btn btn-info text-white w-100 btn-sm fw-bold">Pesan Jasa Sekarang</button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>

    <footer class="text-center text-muted small mt-5 py-4 border-top">
        &copy; 2026 CleanHouse. Tangerang, Indonesia.
    </footer>
</body>
</html>