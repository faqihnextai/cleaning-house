<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Konfirmasi Pembayaran - CleanHouse</title>
    <!-- Fonts & Tailwind -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Source+Sans+3:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        body { font-family: 'Source Sans 3', sans-serif; }
        h1, h2, h3, h4, h5, h6, .font-display { font-family: 'Playfair Display', serif; letter-spacing: -0.02em; }
    </style>
</head>
<body class="bg-[#FAFAF9] text-[#1C1917] min-h-screen antialiased py-12">

    <!-- Simple Nav Header -->
    <header class="max-w-[1200px] mx-auto px-6 mb-8 text-center md:text-left">
        <a href="/" class="text-2xl font-bold text-[#C2410C] font-display">CleanHouse.</a>
    </header>

    <div class="max-w-2xl mx-auto px-4">
        <h3 class="text-3xl font-bold text-[#1C1917] mb-6">Review Pemesanan & Pembayaran</h3>
        
        <!-- Cart Card -->
        <div class="bg-[#F5F5F4] border border-[#D6D3D1] rounded-[12px] p-6 mb-6">
            <h5 class="text-lg font-bold text-[#57534E] mb-4">Rincian Layanan</h5>
            <div class="flex justify-between items-center text-[16px] mb-4">
                <div>
                    <h6 class="text-xl font-bold text-[#1C1917] mb-1"><%= product.name %></h6>
                    <small class="text-[#78716C] text-[14px]">Kuantitas: <%= quantity %> Sesi / Unit</small>
                </div>
                <span class="text-[#1C1917] font-semibold text-[14px]">Rp <%= product.price.toLocaleString('id-ID') %> / sesi</span>
            </div>
            <hr class="border-[#D6D3D1] my-4 opacity-50">
            <div class="flex justify-between items-center mt-4">
                <span class="font-semibold text-[#57534E] text-[14px]">Total Belanjaan:</span>
                <span class="text-3xl font-bold text-[#C2410C] font-display">Rp <%= total.toLocaleString('id-ID') %></span>
            </div>
        </div>

        <form action="/beli/proses" method="POST">
            <input type="hidden" name="product_id" value="<%= product.id %>">
            <input type="hidden" name="quantity" value="<%= quantity %>">

            <!-- Payment Methods -->
            <div class="bg-[#F5F5F4] border border-[#D6D3D1] rounded-[12px] p-6 mb-8">
                <h5 class="text-lg font-bold text-[#57534E] mb-4">Pilih Metode Pembayaran</h5>
                
                <div class="space-y-3">
                    <label class="flex items-center gap-3 p-4 border border-[#D6D3D1] bg-[#FAFAF9] rounded-[8px] cursor-pointer hover:bg-[#E7E5E4]/40 transition-colors text-[14px]">
                        <input type="radio" name="payment_method" value="Transfer Bank" checked class="accent-[#C2410C] h-4 w-4">
                        <span class="font-semibold text-[#1C1917]">🏦 Transfer Bank (VA Mandiri / BCA)</span>
                    </label>
                    
                    <label class="flex items-center gap-3 p-4 border border-[#D6D3D1] bg-[#FAFAF9] rounded-[8px] cursor-pointer hover:bg-[#E7E5E4]/40 transition-colors text-[14px]">
                        <input type="radio" name="payment_method" value="E-Wallet" class="accent-[#C2410C] h-4 w-4">
                        <span class="font-semibold text-[#1C1917]">📱 E-Wallet (Gopay / OVO / Dana)</span>
                    </label>
                    
                    <label class="flex items-center gap-3 p-4 border border-[#D6D3D1] bg-[#FAFAF9] rounded-[8px] cursor-pointer hover:bg-[#E7E5E4]/40 transition-colors text-[14px]">
                        <input type="radio" name="payment_method" value="COD" class="accent-[#C2410C] h-4 w-4">
                        <span class="font-semibold text-[#1C1917]">💵 Bayar di Tempat (COD Lapangan)</span>
                    </label>
                </div>
            </div>

            <!-- CTA Actions -->
            <div class="flex justify-between items-center mb-12">
                <a href="/" class="text-[14px] text-[#57534E] hover:text-[#1C1917] font-semibold">&larr; Batalkan</a>
                <button type="submit" class="bg-[#C2410C] hover:bg-[#9A3412] hover:shadow-[0_4px_12px_rgba(194,65,12,0.25)] text-white font-semibold h-[48px] px-8 rounded-[8px] text-[16px] transition-all duration-150 cursor-pointer">
                    Konfirmasi & Bayar Sekarang
                </button>
            </div>
        </form>
    </div>

</body>
</html>