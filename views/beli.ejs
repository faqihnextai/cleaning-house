<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Konfirmasi Pembayaran - CleanHouse</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3 mb-5">
        <div class="container">
            <a class="navbar-brand fw-bold text-info" href="/">✨ CleanHouse</a>
        </div>
    </nav>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <h3 class="mb-4 fw-bold text-dark">Review Pemesanan & Pembayaran</h3>
                
                <div class="card shadow-sm border-0 mb-4 bg-white">
                    <div class="card-body p-4">
                        <h5 class="fw-bold text-secondary mb-3">Rincian Layanan</h5>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <h6 class="fw-bold mb-1 text-dark"><%= product.name %></h6>
                                <small class="text-muted">Kuantitas: <%= quantity %> Sesi / Unit</small>
                            </div>
                            <span class="text-dark fw-semibold">Rp <%= product.price.toLocaleString('id-ID') %> / sesi</span>
                        </div>
                        <hr class="text-secondary opacity-25">
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="fw-bold text-muted">Total Belanjaan:</span>
                            <span class="fs-4 fw-bold text-info">Rp <%= total.toLocaleString('id-ID') %></span>
                        </div>
                    </div>
                </div>

                <form action="/beli/proses" method="POST">
                    <input type="hidden" name="product_id" value="<%= product.id %>">
                    <input type="hidden" name="quantity" value="<%= quantity %>">

                    <div class="card shadow-sm border-0 mb-4 bg-white">
                        <div class="card-body p-4">
                            <h5 class="fw-bold text-secondary mb-3">Pilih Metode Pembayaran</h5>
                            <div class="form-check p-3 border rounded mb-2 hover:bg-light transition">
                                <input class="form-check-input ms-1 me-3" type="radio" name="payment_method" id="trf" value="Transfer Bank" checked>
                                <label class="form-check-label fw-bold text-dark" for="trf">
                                    🏦 Transfer Bank (VA Mandiri / BCA)
                                </label>
                            </div>
                            <div class="form-check p-3 border rounded mb-2">
                                <input class="form-check-input ms-1 me-3" type="radio" name="payment_method" id="e-wallet" value="E-Wallet">
                                <label class="form-check-label fw-bold text-dark" for="e-wallet">
                                    📱 E-Wallet (Gopay / OVO / Dana)
                                </label>
                            </div>
                            <div class="form-check p-3 border rounded">
                                <input class="form-check-input ms-1 me-3" type="radio" name="payment_method" id="cod" value="COD">
                                <label class="form-check-label fw-bold text-dark" for="cod">
                                    💵 Bayar di Tempat (COD Lapangan)
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-5">
                        <a href="/" class="btn btn-light text-muted btn-sm">&larr; Batalkan</a>
                        <button type="submit" class="btn btn-info text-white btn-lg fw-bold px-5 shadow-sm">Konfirmasi & Bayar Sekarang</button>
                    </div>
                </form>

            </div>
        </div>
    </div>

</body>
</html>