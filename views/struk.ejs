<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nota Pembayaran #INV-<%= order.id %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f4f6f9; }
        .card-receipt { border: 1px dashed #dee2e6; background: #fff; }
        @media print {
            .no-print { display: none !important; }
            body { background: #fff; padding: 0; }
            .container { max-width: 100% !important; width: 100% !important; margin: 0 !important; padding: 0 !important; }
            .card-receipt { border: none !important; }
        }
    </style>
</head>
<body>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            
            <div class="d-flex justify-content-between mb-3 no-print">
                <a href="/" class="btn btn-outline-secondary btn-sm">← Kembali ke Katalog</a>
                <button onclick="window.print()" class="btn btn-success btn-sm">🖨️ Cetak / Simpan PDF</button>
            </div>

            <div class="card card-receipt shadow-sm rounded-0">
                <div class="card-body p-4 p-sm-5">
                    
                    <div class="text-center mb-4">
                        <h3 class="fw-bold text-info mb-1">✨ CleanHouse</h3>
                        <p class="text-muted small mb-0">Jasa Panggilan Pembersihan Rumah Profesional</p>
                        <p class="text-muted small">Tangerang, Indonesia</p>
                        <div class="border-bottom border-secondary opacity-25 my-3"></div>
                    </div>

                    <div class="row g-2 mb-4 small text-muted">
                        <div class="col-6">
                            <span>Nama Pelanggan:</span>
                            <strong class="d-block text-dark mt-1"><%= order.customer_name %></strong>
                        </div>
                        <div class="col-6 text-end">
                            <span>No. Invoice / Waktu:</span>
                            <strong class="d-block text-dark mt-1">#INV-<%= order.id %></strong>
                            <span><%= new Date(order.order_date).toLocaleString('id-ID', { dateStyle: 'medium', timeStyle: 'short' }) %></span>
                        </div>
                    </div>

                    <table class="table table-borderless table-striped my-4 align-middle small">
                        <thead>
                            <tr class="border-bottom text-muted">
                                <th>Deskripsi Jasa</th>
                                <th class="text-center" width="15%">Qty</th>
                                <th class="text-end" width="30%">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% details.forEach(item => { %>
                                <tr>
                                    <td class="fw-bold text-dark"><%= item.service_name %></td>
                                    <td class="text-center"><%= item.quantity %></td>
                                    <td class="text-end text-dark">Rp <%= item.subtotal.toLocaleString('id-ID') %></td>
                                </tr>
                            <% }) %>
                            <tr class="border-top fw-bold">
                                <td colspan="2" class="pt-3 text-end text-muted">Total Bayar:</td>
                                <td class="pt-3 text-end text-info fs-5">Rp <%= order.total_price.toLocaleString('id-ID') %></td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="text-center mt-5 pt-3 border-top border-secondary border-opacity-10">
                        <div class="alert alert-success py-2 small fw-bold mb-3" style="font-size: 12px; letter-spacing: 0.5px;">
                            STATUS TRANSACTION: PAID / LUNAS
                        </div>
                        <p class="text-muted small mb-1">Terima kasih atas kepercayaan Anda.</p>
                        <p class="text-muted xml-small text-center" style="font-size: 11px; line-height: 1.4;">
                            Tim operator lapangan kami akan segera menghubungi nomor telepon akun Anda untuk melakukan konfirmasi jadwal penugasan dan alamat rumah.
                        </p>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

</body>
</html>