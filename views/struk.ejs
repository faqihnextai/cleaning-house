<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nota Pembayaran #INV-<%= order.id %></title>
    <!-- Fonts & Tailwind -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Source+Sans+3:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        body { font-family: 'Source Sans 3', sans-serif; }
        h1, h2, h3, h4, .font-display { font-family: 'Playfair Display', serif; letter-spacing: -0.02em; }
        @media print {
            .no-print { display: none !important; }
            body { background: #FAFAF9; padding: 0; }
            .card-receipt { border: none !important; shadow: none !important; }
        }
    </style>
</head>
<body class="bg-[#FAFAF9] text-[#1C1917] min-h-screen antialiased py-12">

<div class="max-w-[600px] mx-auto px-4">
    
    <!-- Action Buttons -->
    <div class="flex justify-between items-center mb-6 no-print">
        <a href="/" class="text-[14px] text-[#57534E] hover:text-[#1C1917] flex items-center gap-1 font-semibold">
            &larr; Kembali ke Katalog
        </a>
        <button onclick="window.print()" class="bg-[#F5F5F4] hover:bg-[#E7E5E4] border border-[#D6D3D1] text-[#1C1917] font-semibold h-[32px] px-3 rounded-[8px] text-[12px] transition-all cursor-pointer">
            🖨️ Cetak / Simpan PDF
        </button>
    </div>

    <!-- Receipt Card -->
    <div class="card-receipt bg-[#F5F5F4] border border-dashed border-[#D6D3D1] rounded-[12px] p-8 md:p-12 shadow-[0_4px_16px_rgba(28,25,23,0.04)]">
        
        <!-- Header -->
        <div class="text-center mb-8">
            <h3 class="text-3xl font-bold text-[#C2410C] mb-1 font-display">CleanHouse.</h3>
            <p class="text-[#57534E] text-[14px]">Jasa Panggilan Pembersihan Rumah Profesional</p>
            <p class="text-[#78716C] text-[12px]">Tangerang, Indonesia</p>
            <div class="border-b border-[#D6D3D1] my-4 opacity-50"></div>
        </div>

        <!-- Meta Info -->
        <div class="grid grid-cols-2 gap-4 text-[14px] text-[#57534E] mb-6">
            <div>
                <span>Nama Pelanggan:</span>
                <strong class="block text-[#1C1917] mt-0.5"><%= order.customer_name %></strong>
            </div>
            <div class="text-right">
                <span>No. Invoice / Waktu:</span>
                <strong class="block text-[#1C1917] mt-0.5">#INV-<%= order.id %></strong>
                <span class="text-[12px] text-[#78716C]"><%= new Date(order.order_date).toLocaleString('id-ID', { dateStyle: 'medium', timeStyle: 'short' }) %></span>
            </div>
        </div>

        <!-- Items Table -->
        <table class="w-full text-left text-[14px] mb-6">
            <thead>
                <tr class="border-b border-[#D6D3D1] text-[#78716C]">
                    <th class="pb-2 font-semibold">Deskripsi Jasa</th>
                    <th class="pb-2 text-center font-semibold" width="15%">Qty</th>
                    <th class="pb-2 text-right font-semibold" width="30%">Subtotal</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-[#D6D3D1]/40">
                <% details.forEach(item => { %>
                    <tr>
                        <td class="py-3 font-semibold text-[#1C1917]"><%= item.service_name %></td>
                        <td class="py-3 text-center text-[#57534E]"><%= item.quantity %></td>
                        <td class="py-3 text-right text-[#1C1917]">Rp <%= item.subtotal.toLocaleString('id-ID') %></td>
                    </tr>
                <% }) %>
                <tr class="font-bold border-t border-[#D6D3D1]">
                    <td colspan="2" class="pt-4 text-right text-[#57534E]">Total Bayar:</td>
                    <td class="pt-4 text-right text-[#C2410C] text-xl font-display">Rp <%= order.total_price.toLocaleString('id-ID') %></td>
                </tr>
            </tbody>
        </table>

        <!-- Footer Notice -->
        <div class="text-center mt-8 pt-6 border-t border-[#D6D3D1]/50">
            <div class="bg-[#16A34A] text-white py-1.5 rounded-full text-[11px] font-semibold tracking-wide mb-4 uppercase">
                STATUS TRANSACTION: PAID / LUNAS
            </div>
            <p class="text-[#57534E] text-[14px] font-semibold mb-1">Terima kasih atas kepercayaan Anda.</p>
            <p class="text-[#78716C] text-[12px] leading-relaxed max-w-sm mx-auto">
                Tim operator lapangan kami akan segera menghubungi nomor telepon akun Anda untuk melakukan konfirmasi jadwal penugasan dan alamat rumah.
            </p>
        </div>

    </div>
</div>

</body>
</html>